{
  "name": "ikaskey-emoji-form",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "cf-typegen": "wrangler types",
    "dev": "node scripts/gen-version.mjs && waku dev",
    "build": "node scripts/gen-version.mjs && waku build",
    "start": "pnpm build && wrangler dev",
    "start:nobuild": "wrangler dev",
    "migrate:local": "wrangler d1 migrations apply ikaskey-emoji-form --local || wrangler d1 execute ikaskey-emoji-form --local --file=./migrations/0001_init.sql",
    "migrate:remote": "wrangler d1 migrations apply ikaskey-emoji-form --remote || wrangler d1 execute ikaskey-emoji-form --remote --file=./migrations/0001_init.sql",
    "typegen": "waku router typegen",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "hono": "^4.12.14",
    "mfm-js": "0.26.0",
    "react": "~19.2.6",
    "react-dom": "~19.2.6",
    "react-server-dom-webpack": "~19.2.6",
    "waku": "1.0.0-beta.0",
    "wrangler": "^4.90.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.36.3",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "miniflare": "^4.20260507.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}